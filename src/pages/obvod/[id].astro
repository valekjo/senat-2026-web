---
import Layout from '../../layouts/Layout.astro';
import { getDistricts, getDistrict, formatCzechName, getPartyLogoFiles } from '../../lib/data';

export async function getStaticPaths() {
  return getDistricts().map((d) => ({
    params: { id: String(d.id) },
  }));
}

const { id } = Astro.params;
const district = getDistrict(parseInt(id));
if (!district) return Astro.redirect('/');

const base = import.meta.env.BASE_URL;

const sorted = [...district.candidates].sort((a, b) => b.round1Votes - a.round1Votes);
const hasResults = sorted.some((c) => c.round1Votes > 0);
---
<Layout title={`Obvod ${district.id} – ${district.name}`} description={`Kandidáti v obvodu ${district.id} ${district.name}`}>
  <nav class="text-sm mb-6">
    <a href={base} class="transition-opacity hover:opacity-70" style="color: #2a2b66;">← Přehled obvodů</a>
  </nav>

  <div class="mb-8">
    <div class="flex items-center gap-3 mb-1">
      <span
        class="inline-flex items-center justify-center w-10 h-10 rounded-full text-sm font-bold"
        style="background-color: #2a2b66; color: white; border: 2px solid #fa1a5b;"
      >
        {district.id}
      </span>
      <h1 class="text-3xl font-bold" style="color: #2a2b66;">{district.name}</h1>
    </div>
    <p class="text-gray-500 ml-13">{district.candidates.length} kandidátů</p>
  </div>

  <div class="space-y-3">
    {sorted.map((c) => {
      const winner = sorted.filter(x => x.round2Votes > 0).length > 0
        ? sorted.filter(x => x.round2Votes > 0).sort((a, b) => b.round2Votes - a.round2Votes)[0]?.candidateNumber === c.candidateNumber
        : false;
      return (
        <a
          href={`${base}kandidat/${district.id}/${c.candidateNumber}/`}
          class="block rounded-lg px-5 py-4 transition-colors hover:bg-blue-50"
          style="border: 1px solid #e5e7eb;"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-xs text-gray-400 font-mono">#{c.candidateNumber}</span>
                <span class="font-semibold text-gray-900">{formatCzechName(c.name)}</span>
              </div>
              <div class="mt-1 text-sm text-gray-500 flex flex-wrap items-center gap-x-3 gap-y-0.5">
                {getPartyLogoFiles(c.electoralParty).length > 0
                  ? getPartyLogoFiles(c.electoralParty).map((logo) => (
                      <img src={`${base}logos/${logo}`} alt={logo.replace('.svg','')} class="h-5 w-auto" />
                    ))
                  : <span>{c.electoralParty}</span>
                }
                <span>·</span>
                <span>{c.occupation}</span>
                <span>·</span>
                <span>{c.residence}</span>
              </div>
            </div>
          </div>
        </a>
      );
    })}
  </div>
</Layout>
