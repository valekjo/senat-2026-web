---
import fs from 'node:fs';
import path from 'node:path';
import { DISTRICTS } from '../lib/data';

const base = import.meta.env.BASE_URL;

// Mapping from district ID → SVG path element ID (matched via point-in-polygon)
const DISTRICT_PATH: Record<number, string> = {
  3:  'path3593',
  6:  'path3561',
  9:  'path3721',
  12: 'path3649',
  15: 'path3657',
  18: 'path3603',
  21: 'path3755',
  24: 'path3765',
  27: 'path3769',
  30: 'path3545',
  33: 'path3010',
  36: 'path3517',
  39: 'path3515',
  42: 'path3565',
  45: 'path3527',
  48: 'path3555',
  51: 'path3619',
  54: 'path3659',
  57: 'path3637',
  60: 'path3731',
  63: 'path3613',
  66: 'path3599',
  69: 'path3611',
  72: 'path3743',
  75: 'path3581',
  78: 'path3633',
  81: 'path3651',
};

// Load and process SVG at build time
let svg = fs.readFileSync(
  path.resolve(process.cwd(), 'data-raw/senate-map.svg'),
  'utf-8'
);

// Strip XML declaration and make responsive (remove fixed width/height)
svg = svg.replace(/<\?xml[^>]+\?>\s*/, '');
svg = svg.replace(/\swidth="[^"]*"/, '');
svg = svg.replace(/\sheight="[^"]*"/, '');

// Inject class + data-href on each active district path
for (const [idStr] of Object.entries(DISTRICTS)) {
  const id = parseInt(idStr);
  const pathId = DISTRICT_PATH[id];
  if (!pathId) continue;
  const href = `${base}obvod/${id}/`;
  svg = svg.replace(
    new RegExp(`(\\sid="${pathId}")`),
    ` class="s-active" data-href="${href}" aria-label="Obvod ${id} – ${DISTRICTS[id]}"$1`
  );
}
---

<div class="w-full">
  <div class="w-full rounded overflow-hidden">
    <Fragment set:html={svg} />
  </div>

  <!-- Legend -->
  <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 text-sm">
    {Object.entries(DISTRICTS).map(([idStr, name]) => {
      const id = parseInt(idStr);
      return (
        <a
          href={`${base}obvod/${id}/`}
          class="flex items-center gap-2 px-3 py-1.5 rounded border transition-colors hover:bg-blue-50"
          style="border-color: #11457E20;"
        >
          <span
            class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-semibold shrink-0"
            style="background-color: #11457E; color: white;"
          >
            {id}
          </span>
          <span style="color: #11457E;" class="truncate">{name}</span>
        </a>
      );
    })}
  </div>
</div>

<style>
  .s-active {
    cursor: pointer;
    transition: fill 0.2s ease;
  }
  .s-active:hover {
    fill: #bfdbfe !important;
  }
</style>

<script>
  document.querySelectorAll<SVGElement>('.s-active').forEach((el) => {
    el.addEventListener('click', () => {
      const href = el.dataset.href;
      if (href) location.href = href;
    });
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const href = el.dataset.href;
        if (href) location.href = href;
      }
    });
    el.setAttribute('tabindex', '0');
    el.setAttribute('role', 'link');
  });
</script>
